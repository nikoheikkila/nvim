{
  // Align MD013 with textwidth/colorcolumn = 120 (lua/config/options.lua)
  "default": true,
  "MD013": {
    "line_length": 120,
    "heading_line_length": 120,
    "code_block_line_length": 120,
    // Prettier (conform.nvim, on save) re-pads table cells to align pipes and
    // offers no way to turn that off — exempt tables from line-length checks.
    "tables": false
  }
}
